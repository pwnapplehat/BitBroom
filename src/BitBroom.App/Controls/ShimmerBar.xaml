<UserControl x:Class="BitBroom.App.Controls.ShimmerBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="3">
  <Border CornerRadius="1.5" Background="{StaticResource Brush.StrokeSoft}">
    <Border x:Name="Sweep" CornerRadius="1.5">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
          <LinearGradientBrush.RelativeTransform>
            <TranslateTransform x:Name="SweepTransform" X="-1"/>
          </LinearGradientBrush.RelativeTransform>
          <GradientStop Color="#0038BDF8" Offset="0.30"/>
          <GradientStop Color="#FF38BDF8" Offset="0.50"/>
          <GradientStop Color="#0038BDF8" Offset="0.70"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>
  </Border>
</UserControl>
