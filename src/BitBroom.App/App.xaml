<Application x:Class="BitBroom.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:BitBroom.App.Converters"
             ShutdownMode="OnMainWindowClose"
             Startup="OnStartup">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- WPF UI (Fluent) theme + controls, then BitBroom's brand layer on top.
             Surfaces stay stock so the Mica backdrop shows through natively;
             brand lives in the accent color, iconography and splash. -->
        <ui:ThemesDictionary Theme="Dark"/>
        <ui:ControlsDictionary/>
        <ResourceDictionary Source="Themes/Theme.xaml"/>
      </ResourceDictionary.MergedDictionaries>

      <conv:InverseBoolConverter x:Key="InverseBool"/>
      <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
      <conv:BoolToVisibilityConverter x:Key="BoolToVisInverted" Invert="True"/>
      <conv:NullToVisibilityConverter x:Key="NullToVis"/>
      <conv:RiskToBrushConverter x:Key="RiskBrush"/>
      <conv:SeverityToBrushConverter x:Key="SeverityBrush"/>
    </ResourceDictionary>
  </Application.Resources>
</Application>
