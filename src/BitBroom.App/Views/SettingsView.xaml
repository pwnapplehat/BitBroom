<UserControl x:Class="BitBroom.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:anim="clr-namespace:BitBroom.App.Animations"
             anim:Anim.Transition="SlideFade">
  <ScrollViewer VerticalScrollBarVisibility="Auto" DataContext="{Binding SettingsVm}"
                anim:Anim.SmoothScroll="True">
    <StackPanel Margin="28,20,28,28" MaxWidth="820" HorizontalAlignment="Left">
      <TextBlock Text="Settings" Style="{StaticResource Text.Title}"/>

      <TextBlock Text="CLEANING" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <StackPanel>
          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Keep files newer than" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Rule-based categories never delete files younger than this. Protects installers mid-run and apps with fresh temp data. GPU/browser caches ignore this (they are always safe to clear)."/>
            </StackPanel>
            <ComboBox HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="170"
                      SelectedIndex="{Binding MinAgeSelectedIndex}">
              <ComboBoxItem Content="No age limit"/>
              <ComboBoxItem Content="24 hours (default)"/>
              <ComboBoxItem Content="48 hours"/>
              <ComboBoxItem Content="7 days"/>
              <ComboBoxItem Content="30 days"/>
            </ComboBox>
          </Grid>

          <Separator Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,14"/>

          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Simulation mode" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Cleans only write the audit log — nothing is deleted. Perfect for building trust with a new tool."/>
            </StackPanel>
            <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding SimulateOnly}"/>
          </Grid>

          <Separator Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,14"/>

          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Confirm before cleaning" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Show a summary dialog before any deletion starts."/>
            </StackPanel>
            <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding ConfirmBeforeClean}"/>
          </Grid>

          <Separator Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,14"/>

          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Send cleaned files to the Recycle Bin" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="An undo window: everything a clean removes goes to the bin instead of being deleted permanently. Honest trade-off — space is only freed once you empty the bin, and big cleans are slower. Great while you're building trust."/>
            </StackPanel>
            <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding CleanToRecycleBin}"/>
          </Grid>

          <Separator Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,14"/>

          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Try to create a restore point before cleaning" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Honest note: restore points protect system files and the registry — not caches — so this adds little for BitBroom's categories. Off by default. Requires admin and System Protection enabled; Windows also rate-limits creation to one per 24h."/>
            </StackPanel>
            <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding CreateRestorePointBeforeClean}"/>
          </Grid>
        </StackPanel>
      </ui:Card>

      <TextBlock Text="SCHEDULED CLEANING" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <StackPanel>
          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Clean automatically on a schedule" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Registers a Windows Task Scheduler task that runs the safe default set. BitBroom does NOT need to be open and adds no startup entry — Windows launches it at the scheduled time. Runs on battery and catches up if your PC was off; runs without admin (system categories are skipped) and writes an audit log."/>
              <TextBlock Text="{Binding ScheduleStatus}" Style="{StaticResource Text.Caption}" Margin="0,6,0,0"
                         Foreground="{StaticResource Brush.Accent}"/>
            </StackPanel>
            <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center"
                             IsChecked="{Binding ScheduledCleaningEnabled}"
                             IsEnabled="{Binding SchedulingAvailable}"/>
          </Grid>

          <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                      Visibility="{Binding ScheduledCleaningEnabled, Converter={StaticResource BoolToVis}}">
            <ComboBox SelectedIndex="{Binding ScheduleFrequencyIndex}" MinWidth="120" Margin="0,0,8,0">
              <ComboBoxItem Content="Daily"/>
              <ComboBoxItem Content="Weekly"/>
              <ComboBoxItem Content="Monthly"/>
            </ComboBox>
            <ComboBox SelectedIndex="{Binding ScheduleDayIndex}" MinWidth="130" Margin="0,0,8,0"
                      Visibility="{Binding IsWeekly, Converter={StaticResource BoolToVis}}">
              <ComboBoxItem Content="Sunday"/>
              <ComboBoxItem Content="Monday"/>
              <ComboBoxItem Content="Tuesday"/>
              <ComboBoxItem Content="Wednesday"/>
              <ComboBoxItem Content="Thursday"/>
              <ComboBoxItem Content="Friday"/>
              <ComboBoxItem Content="Saturday"/>
            </ComboBox>
            <ComboBox SelectedIndex="{Binding ScheduleHourIndex}" MinWidth="100" Margin="0,0,8,0"
                      ItemsSource="{Binding HourChoices, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <ui:Button Content="Apply schedule" Command="{Binding ApplyScheduleCommand}"/>
          </StackPanel>
        </StackPanel>
      </ui:Card>

      <TextBlock Text="CUSTOM FOLDERS" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <StackPanel>
          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Your own folders to clean" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Appear as the 'Custom folders' category in Clean (off by default, Moderate risk). Files older than 7 days are targeted. The safety guard still refuses protected locations — adding Documents here does nothing."/>
            </StackPanel>
            <ui:Button Content="Add folder" HorizontalAlignment="Right" VerticalAlignment="Center"
                       Command="{Binding AddCustomFolderCommand}"/>
          </Grid>
          <ItemsControl ItemsSource="{Binding CustomFolders}" Margin="0,8,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,3">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Path}" Style="{StaticResource Text.Body}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AgeText}" Style="{StaticResource Text.Caption}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                  </StackPanel>
                  <ui:Button Content="Remove" Appearance="Transparent" HorizontalAlignment="Right"
                             Command="{Binding DataContext.SettingsVm.RemoveCustomFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             CommandParameter="{Binding}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ui:Card>

      <TextBlock Text="EXCLUSIONS" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <StackPanel>
          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Folders BitBroom must never touch" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Excluded paths (and everything under them) are skipped by every scan, clean and duplicate search — enforced in the engine and re-checked at delete time."/>
            </StackPanel>
            <ui:Button Content="Add folder" HorizontalAlignment="Right" VerticalAlignment="Center"
                       Command="{Binding AddExclusionCommand}"/>
          </Grid>
          <ItemsControl ItemsSource="{Binding ExcludedPaths}" Margin="0,8,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,3">
                  <TextBlock Text="{Binding Path}" Style="{StaticResource Text.Body}" VerticalAlignment="Center"/>
                  <ui:Button Content="Remove" Appearance="Transparent" HorizontalAlignment="Right"
                             Command="{Binding DataContext.SettingsVm.RemoveExclusionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             CommandParameter="{Binding}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ui:Card>

      <TextBlock Text="APPEARANCE &amp; SOUND" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <Grid>
          <StackPanel MaxWidth="560" HorizontalAlignment="Left">
            <TextBlock Text="Startup sound" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
            <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                       Text="Play the short broom-sweep chime with the startup animation."/>
          </StackPanel>
          <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding PlayStartupSound}"/>
        </Grid>
      </ui:Card>

      <TextBlock Text="UPDATES" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <StackPanel>
          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Check for updates at startup" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Asks the GitHub releases API once per launch whether a newer version exists. Nothing else is sent — no identifiers, no telemetry. Updates install only when you click Install."/>
            </StackPanel>
            <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding CheckForUpdatesAtStartup}"/>
          </Grid>

          <Separator Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,14"/>

          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Check now" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="One-off manual check. The result lands in the status bar; if an update exists, a banner appears at the top."/>
            </StackPanel>
            <ui:Button Content="Check for updates" HorizontalAlignment="Right" VerticalAlignment="Center"
                       Command="{Binding CheckUpdatesCommand}"/>
          </Grid>
        </StackPanel>
      </ui:Card>

      <TextBlock Text="LOGS &amp; DATA" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <StackPanel>
          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Audit logs" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Every scan/clean writes a timestamped log with the full path and size of every file it deleted (or would delete)."/>
            </StackPanel>
            <ui:Button Content="Open logs folder" HorizontalAlignment="Right" VerticalAlignment="Center"
                       Command="{Binding OpenLogsCommand}"/>
          </Grid>

          <Separator Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,14"/>

          <Grid>
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="Reset lifetime counters" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
              <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                         Text="Clears the 'space freed' and 'items cleaned' statistics."/>
            </StackPanel>
            <ui:Button Content="Reset" HorizontalAlignment="Right" VerticalAlignment="Center"
                       Command="{Binding ResetCountersCommand}"/>
          </Grid>
        </StackPanel>
      </ui:Card>

      <TextBlock Text="PRIVACY" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <TextBlock Style="{StaticResource Text.Body}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="No telemetry, no crash reporting, no accounts — crash logs stay on your disk. The only network request BitBroom can make is the optional GitHub version check above (plus the installer download if you click Install); disable the toggle and it makes zero network requests. What happens on your machine stays on your machine."/>
      </ui:Card>
    </StackPanel>
  </ScrollViewer>
</UserControl>
