<UserControl x:Class="BitBroom.App.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:anim="clr-namespace:BitBroom.App.Animations"
             anim:Anim.Transition="SlideFade">
  <Grid Margin="28,20,28,20" DataContext="{Binding Tools}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="Tools" Style="{StaticResource Text.Title}"/>
      <TextBlock Style="{StaticResource Text.Subtitle}" Margin="0,6,0,0"
                 Text="Supported, documented maintenance actions. Every tool explains what it does before you run it; each runs the official Windows mechanism (DISM, diskpart, pnputil, powercfg…) and streams its output on the right."/>
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="23*"/>
        <ColumnDefinition Width="17*"/>
      </Grid.ColumnDefinitions>

      <!-- Tool list: grouped rows with description + admin badge + Run -->
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,14,0"
                    anim:Anim.SmoothScroll="True">
        <ItemsControl ItemsSource="{Binding Groups}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,0,6,14">
                <TextBlock Text="{Binding Header}" FontSize="11.5" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Accent}" Margin="2,0,0,6"
                           Typography.Capitals="AllSmallCaps"/>
                <ItemsControl ItemsSource="{Binding Tools}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <ui:Card Padding="12,10" Margin="0,0,0,6" VerticalContentAlignment="Stretch">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <ui:SymbolIcon Grid.Column="0" Symbol="{Binding Symbol}" FontSize="19"
                                         Foreground="{StaticResource Brush.Accent}"
                                         VerticalAlignment="Top" Margin="0,2,12,0"/>
                          <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                              <Border Style="{StaticResource Badge}" Margin="8,0,0,0" VerticalAlignment="Center"
                                      Visibility="{Binding RequiresAdmin, Converter={StaticResource BoolToVis}}"
                                      ToolTip="Needs administrator rights — use “Restart as administrator” in the banner">
                                <TextBlock Text="Admin" FontSize="10"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                              </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Description}" FontSize="11.5" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,3,0,0" LineHeight="16"/>
                          </StackPanel>
                          <ui:Button Grid.Column="2" Content="Run" MinWidth="64" VerticalAlignment="Center"
                                     Command="{Binding Command}"
                                     AutomationProperties.Name="{Binding Title}"/>
                        </Grid>
                      </ui:Card>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Live output console -->
      <ui:Card Grid.Column="1" Padding="4" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="OUTPUT" FontSize="10.5" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="10,8,0,4"/>
          <ScrollViewer Grid.Row="1" x:Name="ConsoleScroll" VerticalScrollBarVisibility="Auto">
            <TextBox Text="{Binding ConsoleText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                     FontFamily="Cascadia Mono, Consolas" FontSize="12"
                     Background="Transparent" BorderThickness="0"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     TextChanged="OnConsoleTextChanged"/>
          </ScrollViewer>
        </Grid>
      </ui:Card>
    </Grid>
  </Grid>
</UserControl>
