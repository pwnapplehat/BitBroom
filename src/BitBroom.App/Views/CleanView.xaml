<UserControl x:Class="BitBroom.App.Views.CleanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:anim="clr-namespace:BitBroom.App.Animations"
             xmlns:controls="clr-namespace:BitBroom.App.Controls">
  <Grid DataContext="{Binding Clean}">
    <Grid Margin="28,20,28,20" anim:Anim.Transition="SlideFade">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <Grid Grid.Row="0">
        <StackPanel>
          <TextBlock Text="Clean" Style="{StaticResource Text.Title}"/>
          <TextBlock Style="{StaticResource Text.Subtitle}" Margin="0,6,0,0"
                     Text="Scan measures every category (read-only). Review sizes, then clean what you selected."/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
          <ui:Button Content="Select defaults" Appearance="Transparent" Command="{Binding SelectDefaultsCommand}" Margin="0,0,6,0"/>
          <ui:Button Content="Select none" Appearance="Transparent" Command="{Binding SelectNoneCommand}" Margin="0,0,12,0"/>
          <ui:Button Content="Cancel" Command="{Binding CancelCommand}" Margin="0,0,8,0"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
          <ui:Button Content="Scan" Appearance="Primary" Command="{Binding ScanCommand}" MinWidth="110">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="Search24"/>
            </ui:Button.Icon>
          </ui:Button>
        </StackPanel>
      </Grid>

      <!-- Progress / results strip -->
      <StackPanel Grid.Row="1" Margin="0,14,0,10">
        <controls:ShimmerBar Margin="0,0,0,8"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
        <TextBlock Text="{Binding ProgressText}" FontSize="12.5" Foreground="{StaticResource Brush.Accent}"
                   Visibility="{Binding ProgressText, Converter={StaticResource NullToVis}}"/>
        <Grid Visibility="{Binding ResultSummary, Converter={StaticResource NullToVis}}">
          <ui:InfoBar Severity="Success" IsClosable="False" IsOpen="True"
                      Title="{Binding ResultSummary}"/>
          <ui:Button Content="Open audit log" Appearance="Transparent" Command="{Binding OpenLogCommand}"
                     HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"
                     Visibility="{Binding ResultLogPath, Converter={StaticResource NullToVis}}"/>
        </Grid>
      </StackPanel>

      <!-- Category list -->
      <ui:Card Grid.Row="2" Padding="6" VerticalContentAlignment="Stretch">
        <ListBox ItemsSource="{Binding GroupedCategories}" ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.CanContentScroll="False"
                 Background="Transparent" BorderThickness="0"
                 ItemContainerStyle="{StaticResource BareListBoxItem}"
                 anim:Anim.SmoothScroll="True"
                 anim:Anim.StaggerChildren="True">
          <ListBox.GroupStyle>
            <GroupStyle>
              <GroupStyle.HeaderTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" Style="{StaticResource Text.Section}" Margin="12,14,0,6"/>
                </DataTemplate>
              </GroupStyle.HeaderTemplate>
            </GroupStyle>
          </ListBox.GroupStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border x:Name="Row" CornerRadius="6" Padding="10,8" Margin="4,1">
                <Border.Background>
                  <SolidColorBrush Color="Transparent"/>
                </Border.Background>
                <Border.Style>
                  <Style TargetType="Border">
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                          <BeginStoryboard>
                            <Storyboard>
                              <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                              To="#12FFFFFF" Duration="0:0:0.12"/>
                            </Storyboard>
                          </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                          <BeginStoryboard>
                            <Storyboard>
                              <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                              To="#00FFFFFF" Duration="0:0:0.25"/>
                            </Storyboard>
                          </BeginStoryboard>
                        </Trigger.ExitActions>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="110"/>
                  </Grid.ColumnDefinitions>

                  <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center"
                            IsEnabled="{Binding AdminLocked, Converter={StaticResource InverseBool}}"/>

                  <StackPanel Grid.Column="1" Margin="10,0,10,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Name}" Style="{StaticResource Text.Body}" FontWeight="Medium"/>
                      <TextBlock Text="&#xE72E;" FontFamily="{StaticResource Font.Icons}" FontSize="11"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center"
                                 Visibility="{Binding AdminLocked, Converter={StaticResource BoolToVis}}"
                                 ToolTip="Requires administrator — use the banner button to restart elevated."/>
                    </StackPanel>
                    <TextBlock Text="{Binding Description}" Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                    <TextBlock Text="{Binding ScanNote}" Style="{StaticResource Text.Caption}" Foreground="{StaticResource Brush.AccentDeep}"
                               Visibility="{Binding ScanNote, Converter={StaticResource NullToVis}}"/>
                  </StackPanel>

                  <Border Grid.Column="2" Style="{StaticResource Badge}" Background="#141B2B45" Margin="0,0,10,0">
                    <TextBlock Text="{Binding RiskLabel}" FontSize="9.5" FontWeight="SemiBold"
                               Foreground="{Binding Risk, Converter={StaticResource RiskBrush}}"/>
                  </Border>

                  <TextBlock Grid.Column="3" Text="{Binding SizeText}" FontSize="13.5" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ui:Card>

      <!-- Footer -->
      <Grid Grid.Row="3" Margin="0,14,0,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Style="{StaticResource Text.Body}" VerticalAlignment="Center">
            <Run Text="Selected:"/>
            <Run Text="{Binding SelectedBytesText, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}"/>
          </TextBlock>
          <Border Style="{StaticResource Badge}" Background="#26343F52" Margin="12,0,0,0"
                  Visibility="{Binding SimulateOnly, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="SIMULATION MODE" FontSize="10" Foreground="{StaticResource Brush.Warning}"/>
          </Border>
        </StackPanel>
        <ui:Button HorizontalAlignment="Right" Appearance="Primary" MinWidth="150"
                   Content="Clean selected" Command="{Binding CleanCommand}">
          <ui:Button.Icon>
            <ui:SymbolIcon Symbol="Broom24"/>
          </ui:Button.Icon>
        </ui:Button>
      </Grid>
    </Grid>

    <!-- Confirm overlay -->
    <Grid Background="#B00A0D14" Visibility="{Binding ConfirmVisible, Converter={StaticResource BoolToVis}}"
          anim:Anim.Transition="Fade">
      <Border MaxWidth="560" VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="{DynamicResource ApplicationBackgroundBrush}"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1" CornerRadius="10" Padding="24"
              anim:Anim.Transition="ZoomFade">
        <StackPanel>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource Font.Icons}" FontSize="18"
                       Foreground="{StaticResource Brush.Warning}" VerticalAlignment="Center"/>
            <TextBlock Text="Confirm clean" FontSize="17" FontWeight="SemiBold"
                       FontFamily="{StaticResource Font.Display}"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="10,0,0,0"/>
          </StackPanel>
          <TextBlock Text="{Binding ConfirmText}" Style="{StaticResource Text.Body}" Margin="0,14,0,0"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <ui:Button Content="Cancel" Command="{Binding CancelConfirmCommand}" MinWidth="90" Margin="0,0,8,0"/>
            <ui:Button Content="Clean now" Appearance="Primary" Command="{Binding ConfirmCleanCommand}" MinWidth="110"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
