<UserControl x:Class="BitBroom.App.Views.HogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:anim="clr-namespace:BitBroom.App.Animations"
             xmlns:controls="clr-namespace:BitBroom.App.Controls"
             anim:Anim.Transition="SlideFade">
  <Grid Margin="28,20,28,20" DataContext="{Binding Hogs}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <StackPanel>
        <TextBlock Text="Space Hogs" Style="{StaticResource Text.Title}"/>
        <TextBlock Style="{StaticResource Text.Subtitle}" Margin="0,6,0,0"
                   Text="The hidden consumers behind “my C: drive filled up for no reason” — hibernation files, WSL/Docker disks, restore points, search indexes, known Windows bugs. Report-only: each finding explains the safe, supported fix."/>
      </StackPanel>
      <ui:Button Content="Inspect" Appearance="Primary" Command="{Binding InspectCommand}" MinWidth="110"
                 HorizontalAlignment="Right" VerticalAlignment="Top">
        <ui:Button.Icon>
          <ui:SymbolIcon Symbol="Search24"/>
        </ui:Button.Icon>
      </ui:Button>
    </Grid>

    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto"
                  anim:Anim.SmoothScroll="True">
      <StackPanel>
        <controls:ShimmerBar Margin="0,0,0,14"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
        <TextBlock Text="Nothing notable found — no oversized hidden consumers detected."
                   Style="{StaticResource Text.Body}" Foreground="{StaticResource Brush.Success}"
                   Visibility="{Binding NothingFound, Converter={StaticResource BoolToVis}}"/>
        <ItemsControl ItemsSource="{Binding Hogs}" anim:Anim.StaggerChildren="True">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <ui:Card Margin="0,0,0,10">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                      <Border Style="{StaticResource Badge}" Background="#141B2B45" Margin="0,0,10,0">
                        <TextBlock Text="{Binding SeverityLabel}" FontSize="9.5" FontWeight="SemiBold"
                                   Foreground="{Binding Severity, Converter={StaticResource SeverityBrush}}"/>
                      </Border>
                      <TextBlock Text="{Binding Title}" FontSize="14.5" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Detail}" Style="{StaticResource Text.Caption}" Margin="0,8,0,0" FontSize="12"/>
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="10,8" Margin="0,10,0,0">
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEA80;" FontFamily="{StaticResource Font.Icons}" FontSize="12"
                                   Foreground="{StaticResource Brush.Accent}" VerticalAlignment="Top" Margin="0,2,8,0"/>
                        <TextBlock Text="{Binding Guidance}" Style="{StaticResource Text.Caption}" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxWidth="760"/>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="16,0,0,0" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding SizeText}" FontSize="19" FontWeight="SemiBold"
                               FontFamily="{StaticResource Font.Display}"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Right"/>
                    <ui:Button Content="Open location" Appearance="Transparent" Margin="0,8,0,0"
                               Visibility="{Binding HasPath, Converter={StaticResource BoolToVis}}"
                               Command="{Binding DataContext.Hogs.OpenPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               CommandParameter="{Binding}"/>
                  </StackPanel>
                </Grid>
              </ui:Card>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
