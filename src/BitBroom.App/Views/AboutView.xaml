<UserControl x:Class="BitBroom.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:anim="clr-namespace:BitBroom.App.Animations"
             anim:Anim.Transition="SlideFade">
  <ScrollViewer VerticalScrollBarVisibility="Auto" anim:Anim.SmoothScroll="True">
    <StackPanel Margin="28,20,28,28" MaxWidth="820" HorizontalAlignment="Left">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#xEA99;" FontFamily="{StaticResource Font.Icons}" FontSize="28"
                   Foreground="{StaticResource Brush.Accent}" VerticalAlignment="Center"/>
        <StackPanel Margin="14,0,0,0">
          <TextBlock Text="BitBroom" Style="{StaticResource Text.Title}"/>
          <TextBlock Text="{Binding VersionText}" Style="{StaticResource Text.Subtitle}"/>
        </StackPanel>
      </StackPanel>

      <TextBlock Style="{StaticResource Text.Body}" Margin="0,18,0,0"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                 Text="A safety-first, open-source disk cleaner for Windows. BitBroom exists because 'my C: drive is full and I don't know why' shouldn't require a computer science degree — and because the tools that promise to fix it shouldn't be scarier than the problem."/>

      <TextBlock Text="PRINCIPLES" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <TextBlock Style="{StaticResource Text.Body}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="1. Safety beats free space — a guard validates every path twice, junctions are never followed, user content is untouchable by design.&#x0a;2. Honesty beats marketing — no registry cleaner, no 'RAM optimizer', no fake speed claims. When a fix belongs to Windows (DISM, powercfg), BitBroom runs the official tool and shows you its output.&#x0a;3. Transparency beats trust-me — open source, audit logs for every deletion, simulation mode, no telemetry (the only network touch is the optional update check in Settings)."/>
      </ui:Card>

      <TextBlock Text="LICENSE" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <TextBlock Style="{StaticResource Text.Body}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="MIT License — free to use, study, modify and share. Built with .NET and WPF; the interface uses the MIT-licensed WPF UI (Fluent) library — the cleaning engine itself has zero third-party dependencies. Category research is grounded in Microsoft documentation, vendor guidance and years of community knowledge (Winapp2, BleachBit)."/>
      </ui:Card>

      <TextBlock Text="DISCLAIMER" Style="{StaticResource Text.Section}" Margin="0,22,0,10"/>
      <ui:Card>
        <TextBlock Style="{StaticResource Text.Body}" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   Text="Provided 'as is', without warranty of any kind. BitBroom only deletes files that are regenerable by design, but disk cleaning is inherently destructive — read what a category does before enabling it, and keep backups of anything you cannot afford to lose (that advice applies to every tool, not just this one)."/>
      </ui:Card>
    </StackPanel>
  </ScrollViewer>
</UserControl>
