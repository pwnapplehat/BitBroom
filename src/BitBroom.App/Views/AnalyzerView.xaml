<UserControl x:Class="BitBroom.App.Views.AnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:anim="clr-namespace:BitBroom.App.Animations"
             xmlns:controls="clr-namespace:BitBroom.App.Controls"
             anim:Anim.Transition="SlideFade">
  <Grid Margin="28,20,28,20" DataContext="{Binding Analyzer}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0">
      <StackPanel>
        <TextBlock Text="Disk Analyzer" Style="{StaticResource Text.Title}"/>
        <TextBlock Style="{StaticResource Text.Subtitle}" Margin="0,6,0,0"
                   Text="Find out where your space actually went. Junctions are never followed; deletions from here go to the Recycle Bin."/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
        <ComboBox ItemsSource="{Binding DriveChoices}" IsEditable="False"
                  SelectedItem="{Binding TargetPath}" MinWidth="200" Margin="0,0,10,0"/>
        <ui:Button Content="Cancel" Command="{Binding CancelCommand}" Margin="0,0,8,0"
                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
        <ui:Button Content="Analyze" Appearance="Primary" Command="{Binding AnalyzeCommand}" MinWidth="110">
          <ui:Button.Icon>
            <ui:SymbolIcon Symbol="DataPie24"/>
          </ui:Button.Icon>
        </ui:Button>
      </StackPanel>
    </Grid>

    <!-- Progress -->
    <StackPanel Grid.Row="1" Margin="0,12,0,10">
      <controls:ShimmerBar Margin="0,0,0,8"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
      <TextBlock Text="{Binding ProgressText}" FontSize="12" Foreground="{StaticResource Brush.Accent}"
                 Visibility="{Binding ProgressText, Converter={StaticResource NullToVis}}"/>
      <TextBlock Text="{Binding SummaryText}" FontSize="12.5"
                 Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                 Visibility="{Binding SummaryText, Converter={StaticResource NullToVis}}"/>
    </StackPanel>

    <!-- Results -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="11*"/>
        <ColumnDefinition Width="14"/>
        <ColumnDefinition Width="9*"/>
      </Grid.ColumnDefinitions>

      <!-- Folder tree. WPF UI's Card defaults to VerticalAlignment=Center, which made
           this card hug its content and float mid-row; stretch keeps both cards
           top-aligned and full height. -->
      <ui:Card Grid.Column="0" Padding="8" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="FOLDERS BY SIZE" Style="{StaticResource Text.Section}" Margin="8,4,0,8"/>
          <TreeView Grid.Row="1" ItemsSource="{Binding RootNodes}">
            <TreeView.ItemTemplate>
              <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                <Grid Margin="0,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource Text.Body}"
                             TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                             ToolTip="{Binding FullPath}"/>
                  <Grid Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                    <Border Background="{StaticResource Brush.StrokeSoft}" Height="7" CornerRadius="3"/>
                    <Border Background="{StaticResource Brush.Accent}" Height="7" CornerRadius="3"
                            HorizontalAlignment="Left" Width="{Binding BarWidth}"/>
                  </Grid>
                  <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontSize="12.5" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                  <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10,0,16,0">
                    <ui:Button Appearance="Transparent" Padding="6,4" ToolTip="Open in Explorer"
                               Command="{Binding DataContext.Analyzer.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               CommandParameter="{Binding}">
                      <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"/>
                      </ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Appearance="Transparent" Padding="6,4" ToolTip="Send to Recycle Bin…"
                               Command="{Binding DataContext.Analyzer.RecycleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               CommandParameter="{Binding}">
                      <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Delete24" FontSize="14"/>
                      </ui:Button.Icon>
                    </ui:Button>
                  </StackPanel>
                </Grid>
              </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
      </ui:Card>

      <!-- Largest files -->
      <ui:Card Grid.Column="2" Padding="8" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="LARGEST FILES" Style="{StaticResource Text.Section}" Margin="8,4,0,8"/>
          <ListBox Grid.Row="1" ItemsSource="{Binding LargestFiles}"
                   ScrollViewer.CanContentScroll="False"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   Background="Transparent" BorderThickness="0"
                   ItemContainerStyle="{StaticResource BareListBoxItem}"
                   anim:Anim.SmoothScroll="True"
                   anim:Anim.StaggerChildren="True">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border CornerRadius="5" Padding="8,6" Margin="2,1,8,1" Background="Transparent">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{Binding Name}" Style="{StaticResource Text.Body}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Directory}" Style="{StaticResource Text.Caption}" TextTrimming="CharacterEllipsis"
                                 ToolTip="{Binding Path}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" Margin="10,0"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                      <ui:Button Appearance="Transparent" Padding="6,4" ToolTip="Open in Explorer"
                                 Command="{Binding DataContext.Analyzer.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 CommandParameter="{Binding}">
                        <ui:Button.Icon>
                          <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"/>
                        </ui:Button.Icon>
                      </ui:Button>
                      <ui:Button Appearance="Transparent" Padding="6,4" ToolTip="Send to Recycle Bin…"
                                 Command="{Binding DataContext.Analyzer.RecycleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 CommandParameter="{Binding}">
                        <ui:Button.Icon>
                          <ui:SymbolIcon Symbol="Delete24" FontSize="14"/>
                        </ui:Button.Icon>
                      </ui:Button>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </ui:Card>
    </Grid>
  </Grid>
</UserControl>
