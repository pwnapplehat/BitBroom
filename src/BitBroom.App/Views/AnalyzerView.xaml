<UserControl x:Class="BitBroom.App.Views.AnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:anim="clr-namespace:BitBroom.App.Animations"
             xmlns:controls="clr-namespace:BitBroom.App.Controls"
             anim:Anim.Transition="SlideFade">
  <Grid x:Name="AnalyzerRoot" Margin="28,24,28,20" DataContext="{Binding Analyzer}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0">
      <StackPanel>
        <TextBlock Text="Disk Analyzer" Style="{StaticResource Text.Title}"/>
        <TextBlock Style="{StaticResource Text.Subtitle}" Margin="0,6,0,0"
                   Text="Find out where your space actually went. Junctions are never followed; deletions from here go to the Recycle Bin."/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
        <ComboBox ItemsSource="{Binding DriveChoices}" IsEditable="False"
                  SelectedItem="{Binding TargetPath}" MinWidth="200" Margin="0,0,10,0"/>
        <Button Content="Cancel" Command="{Binding CancelCommand}" Margin="0,0,8,0"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
        <Button Command="{Binding AnalyzeCommand}" Style="{StaticResource Button.Accent}" MinWidth="110">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE9D2;" FontFamily="{StaticResource Font.Icons}" FontSize="13" VerticalAlignment="Center"/>
            <TextBlock Text="Analyze" Margin="8,0,0,0"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Progress -->
    <StackPanel Grid.Row="1" Margin="0,12,0,10">
      <controls:ShimmerBar Margin="0,0,0,8"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
      <TextBlock Text="{Binding ProgressText}" FontSize="12" Foreground="{StaticResource Brush.Accent}"
                 Visibility="{Binding ProgressText, Converter={StaticResource NullToVis}}"/>
      <TextBlock Text="{Binding SummaryText}" FontSize="12.5" Foreground="{StaticResource Brush.TextSecondary}"
                 Visibility="{Binding SummaryText, Converter={StaticResource NullToVis}}"/>
    </StackPanel>

    <!-- Results -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3*"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="2*"/>
      </Grid.ColumnDefinitions>

      <!-- Folder tree -->
      <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="FOLDERS BY SIZE" Style="{StaticResource Text.Section}" Margin="8,4,0,8"/>
          <TreeView Grid.Row="1" ItemsSource="{Binding RootNodes}">
            <TreeView.ItemTemplate>
              <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                <Grid Margin="0,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource Text.Body}"
                             TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                             ToolTip="{Binding FullPath}"/>
                  <Grid Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                    <Border Background="{StaticResource Brush.StrokeSoft}" Height="7" CornerRadius="3"/>
                    <Border Background="{StaticResource Brush.Accent}" Height="7" CornerRadius="3"
                            HorizontalAlignment="Left" Width="{Binding BarWidth}"/>
                  </Grid>
                  <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontSize="12.5" FontWeight="SemiBold"
                             Foreground="{StaticResource Brush.Text}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                  <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10,0,4,0">
                    <Button Content="&#xE838;" FontFamily="{StaticResource Font.Icons}" FontSize="11" Padding="6,4"
                            Style="{StaticResource Button.Subtle}" ToolTip="Open in Explorer"
                            Command="{Binding DataContext.Analyzer.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"/>
                    <Button Content="&#xE74D;" FontFamily="{StaticResource Font.Icons}" FontSize="11" Padding="6,4"
                            Style="{StaticResource Button.Subtle}" ToolTip="Send to Recycle Bin…"
                            Command="{Binding DataContext.Analyzer.RecycleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"/>
                  </StackPanel>
                </Grid>
              </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
      </Border>

      <!-- Largest files -->
      <Border Grid.Column="2" Style="{StaticResource Card}" Padding="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="LARGEST FILES" Style="{StaticResource Text.Section}" Margin="8,4,0,8"/>
          <ListBox Grid.Row="1" ItemsSource="{Binding LargestFiles}"
                   ScrollViewer.CanContentScroll="False"
                   anim:Anim.SmoothScroll="True"
                   anim:Anim.StaggerChildren="True">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border CornerRadius="5" Padding="8,6" Margin="2,1" Background="Transparent">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{Binding Name}" Style="{StaticResource Text.Body}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Directory}" Style="{StaticResource Text.Caption}" TextTrimming="CharacterEllipsis"
                                 ToolTip="{Binding Path}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.Text}" VerticalAlignment="Center" Margin="10,0"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                      <Button Content="&#xE838;" FontFamily="{StaticResource Font.Icons}" FontSize="11" Padding="6,4"
                              Style="{StaticResource Button.Subtle}" ToolTip="Open in Explorer"
                              Command="{Binding DataContext.Analyzer.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}"/>
                      <Button Content="&#xE74D;" FontFamily="{StaticResource Font.Icons}" FontSize="11" Padding="6,4"
                              Style="{StaticResource Button.Subtle}" ToolTip="Send to Recycle Bin…"
                              Command="{Binding DataContext.Analyzer.RecycleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
