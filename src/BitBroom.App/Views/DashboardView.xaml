<UserControl x:Class="BitBroom.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:anim="clr-namespace:BitBroom.App.Animations"
             anim:Anim.Transition="SlideFade">
  <ScrollViewer VerticalScrollBarVisibility="Auto" anim:Anim.SmoothScroll="True">
    <StackPanel Margin="28,20,28,28" MaxWidth="1100" HorizontalAlignment="Stretch">

      <TextBlock Text="Dashboard" Style="{StaticResource Text.Title}"/>
      <TextBlock Style="{StaticResource Text.Subtitle}" Margin="0,6,0,0"
                 Text="A quick look at your drives and what BitBroom has reclaimed so far."/>

      <!-- Stats row -->
      <UniformGrid Columns="3" Margin="0,20,0,0">
        <ui:Card Margin="0,0,8,0" VerticalContentAlignment="Stretch">
          <StackPanel>
            <TextBlock Text="LIFETIME SPACE FREED" Style="{StaticResource Text.Section}"/>
            <TextBlock Text="{Binding LifetimeFreedText}" FontSize="30" FontWeight="SemiBold"
                       FontFamily="{StaticResource Font.Display}"
                       Foreground="{StaticResource Brush.Success}" Margin="0,8,0,0"/>
          </StackPanel>
        </ui:Card>
        <ui:Card Margin="4,0" VerticalContentAlignment="Stretch">
          <StackPanel>
            <TextBlock Text="ITEMS CLEANED" Style="{StaticResource Text.Section}"/>
            <TextBlock Text="{Binding LifetimeItemsText}" FontSize="30" FontWeight="SemiBold"
                       FontFamily="{StaticResource Font.Display}"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,8,0,0"/>
          </StackPanel>
        </ui:Card>
        <ui:Card Margin="8,0,0,0" VerticalContentAlignment="Stretch">
          <StackPanel>
            <TextBlock Text="LAST CLEAN" Style="{StaticResource Text.Section}"/>
            <TextBlock Text="{Binding LastCleanText}" FontSize="22" FontWeight="SemiBold"
                       FontFamily="{StaticResource Font.Display}"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,12,0,0"/>
          </StackPanel>
        </ui:Card>
      </UniformGrid>

      <!-- Drives -->
      <TextBlock Text="DRIVES" Style="{StaticResource Text.Section}" Margin="0,26,0,10"/>
      <ItemsControl ItemsSource="{Binding Drives}" anim:Anim.StaggerChildren="True">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ui:Card Margin="0,0,0,10">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xEDA2;" FontFamily="{StaticResource Font.Icons}" FontSize="22"
                           Foreground="{StaticResource Brush.Accent}" VerticalAlignment="Center" Margin="2,0,16,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="{Binding Label}" FontSize="13"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                  </StackPanel>
                  <ProgressBar Value="{Binding UsedFraction, Mode=OneWay}" Maximum="1" Margin="0,8,0,0" Height="6"
                               anim:Anim.AnimateValue="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="18,0,0,0">
                  <TextBlock Text="{Binding UsageText}" FontSize="12.5"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                  <TextBlock Text="Low space" FontSize="11" Foreground="{StaticResource Brush.Danger}" HorizontalAlignment="Right"
                             Visibility="{Binding IsLow, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
              </Grid>
            </ui:Card>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Get started -->
      <Border Style="{StaticResource Card.Accent}" Margin="0,16,0,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="Reclaim disk space now" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text}"/>
            <TextBlock Style="{StaticResource Text.Subtitle}" Margin="0,4,0,0"
                       Text="Run a scan to measure caches, dumps, logs and leftovers. Scanning is read-only — you review everything before a single file is deleted."/>
          </StackPanel>
          <ui:Button Grid.Column="1" Content="Go to Clean" Appearance="Primary"
                     VerticalAlignment="Center" Command="{Binding NavigateToCleanCommand}">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="Broom24"/>
            </ui:Button.Icon>
          </ui:Button>
        </Grid>
      </Border>

      <!-- Safety promise -->
      <ui:Card Margin="0,10,0,0">
        <StackPanel>
          <TextBlock Text="THE BITBROOM SAFETY MODEL" Style="{StaticResource Text.Section}"/>
          <TextBlock Style="{StaticResource Text.Body}" Margin="0,8,0,0"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     Text="• Never touches Documents, Desktop, Pictures, Downloads or any user content folder — enforced by a path guard, not by convention.&#x0a;• Never follows junctions or symlinks, and never deletes OneDrive cloud placeholders.&#x0a;• Files modified in the last 24 hours are kept (configurable), so running apps and installers are undisturbed.&#x0a;• No registry cleaning — it's risk without benefit. No telemetry, no network calls, ever.&#x0a;• Every deletion lands in a plain-text audit log you can open from the status bar."/>
        </StackPanel>
      </ui:Card>

    </StackPanel>
  </ScrollViewer>
</UserControl>
