<Window x:Class="BitBroom.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BitBroom.App.Views"
        Title="BitBroom"
        Icon="/Assets/icon.ico"
        Width="1280" Height="820" MinWidth="1080" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Bg}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        FontFamily="Segoe UI Variable Text, Segoe UI">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="34" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="-1"/>
  </WindowChrome.WindowChrome>

  <Window.Resources>
    <!-- ══════════ Startup intro: broom sweeps three "bits" away, wordmark pops,
                    then the splash cross-dissolves into the (slightly zooming) app. -->
    <Storyboard x:Key="SplashIntro">
      <DoubleAnimation Storyboard.TargetName="SplashLogo" Storyboard.TargetProperty="Opacity"
                       From="0" To="1" Duration="0:0:0.25"/>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SplashRotate" Storyboard.TargetProperty="Angle">
        <DiscreteDoubleKeyFrame KeyTime="0" Value="-26"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.42" Value="16">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:0.68" Value="-11">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:0.88" Value="6">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.05" Value="0">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
      </DoubleAnimationUsingKeyFrames>

      <!-- Bit 1 -->
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bit1" Storyboard.TargetProperty="Opacity">
        <DiscreteDoubleKeyFrame KeyTime="0:0:0.30" Value="1"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.88" Value="0"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimation Storyboard.TargetName="Bit1Move" Storyboard.TargetProperty="X"
                       From="0" To="70" BeginTime="0:0:0.30" Duration="0:0:0.58">
        <DoubleAnimation.EasingFunction>
          <CubicEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetName="Bit1Move" Storyboard.TargetProperty="Y"
                       From="0" To="-16" BeginTime="0:0:0.30" Duration="0:0:0.58">
        <DoubleAnimation.EasingFunction>
          <CubicEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>

      <!-- Bit 2 -->
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bit2" Storyboard.TargetProperty="Opacity">
        <DiscreteDoubleKeyFrame KeyTime="0:0:0.44" Value="1"/>
        <EasingDoubleKeyFrame KeyTime="0:0:1.02" Value="0"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimation Storyboard.TargetName="Bit2Move" Storyboard.TargetProperty="X"
                       From="0" To="92" BeginTime="0:0:0.44" Duration="0:0:0.58">
        <DoubleAnimation.EasingFunction>
          <CubicEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetName="Bit2Move" Storyboard.TargetProperty="Y"
                       From="0" To="-4" BeginTime="0:0:0.44" Duration="0:0:0.58">
        <DoubleAnimation.EasingFunction>
          <CubicEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>

      <!-- Bit 3 -->
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bit3" Storyboard.TargetProperty="Opacity">
        <DiscreteDoubleKeyFrame KeyTime="0:0:0.56" Value="1"/>
        <EasingDoubleKeyFrame KeyTime="0:0:1.14" Value="0"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimation Storyboard.TargetName="Bit3Move" Storyboard.TargetProperty="X"
                       From="0" To="112" BeginTime="0:0:0.56" Duration="0:0:0.58">
        <DoubleAnimation.EasingFunction>
          <CubicEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetName="Bit3Move" Storyboard.TargetProperty="Y"
                       From="0" To="-24" BeginTime="0:0:0.56" Duration="0:0:0.58">
        <DoubleAnimation.EasingFunction>
          <CubicEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>

      <!-- Wordmark -->
      <DoubleAnimation Storyboard.TargetName="SplashTitle" Storyboard.TargetProperty="Opacity"
                       From="0" To="1" BeginTime="0:0:0.55" Duration="0:0:0.35"/>
      <DoubleAnimation Storyboard.TargetName="TitleScale" Storyboard.TargetProperty="ScaleX"
                       From="0.92" To="1" BeginTime="0:0:0.55" Duration="0:0:0.45">
        <DoubleAnimation.EasingFunction>
          <QuinticEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetName="TitleScale" Storyboard.TargetProperty="ScaleY"
                       From="0.92" To="1" BeginTime="0:0:0.55" Duration="0:0:0.45">
        <DoubleAnimation.EasingFunction>
          <QuinticEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetName="SplashTag" Storyboard.TargetProperty="Opacity"
                       From="0" To="1" BeginTime="0:0:0.85" Duration="0:0:0.3"/>

      <!-- Cross-dissolve into the app -->
      <DoubleAnimation Storyboard.TargetName="Splash" Storyboard.TargetProperty="Opacity"
                       From="1" To="0" BeginTime="0:0:1.5" Duration="0:0:0.35"/>
      <DoubleAnimation Storyboard.TargetName="Shell" Storyboard.TargetProperty="Opacity"
                       From="0" To="1" BeginTime="0:0:1.45" Duration="0:0:0.45"/>
      <DoubleAnimation Storyboard.TargetName="ShellScale" Storyboard.TargetProperty="ScaleX"
                       From="0.985" To="1" BeginTime="0:0:1.45" Duration="0:0:0.55">
        <DoubleAnimation.EasingFunction>
          <QuinticEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetName="ShellScale" Storyboard.TargetProperty="ScaleY"
                       From="0.985" To="1" BeginTime="0:0:1.45" Duration="0:0:0.55">
        <DoubleAnimation.EasingFunction>
          <QuinticEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
    </Storyboard>
  </Window.Resources>

  <Grid>

  <Grid x:Name="Shell" RenderTransformOrigin="0.5,0.5">
    <Grid.RenderTransform>
      <ScaleTransform x:Name="ShellScale" ScaleX="1" ScaleY="1"/>
    </Grid.RenderTransform>
    <Grid.RowDefinitions>
      <RowDefinition Height="34"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- ══════════ Title bar ══════════ -->
    <Grid Grid.Row="0" Background="{StaticResource Brush.Bg}">
      <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="&#xEA99;" FontFamily="{StaticResource Font.Icons}" FontSize="14"
                   Foreground="{StaticResource Brush.Accent}" VerticalAlignment="Center"/>
        <TextBlock Text="BitBroom" Margin="8,0,0,0" FontSize="12.5" FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.Text}" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding VersionText}" Margin="8,0,0,0" FontSize="11"
                   Foreground="{StaticResource Brush.TextTertiary}" VerticalAlignment="Center"/>
        <Border Style="{StaticResource Badge}" Background="#26343F52" Margin="10,0,0,0"
                Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="Administrator" FontSize="10.5" Foreground="{StaticResource Brush.Success}"/>
        </Border>
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Style="{StaticResource Button.Caption}" Content="&#xE921;" Click="OnMinimize"/>
        <Button x:Name="MaximizeButton" Style="{StaticResource Button.Caption}" Content="&#xE922;" Click="OnMaximizeRestore"/>
        <Button Style="{StaticResource Button.CaptionClose}" Content="&#xE8BB;" Click="OnClose"/>
      </StackPanel>
    </Grid>

    <!-- ══════════ Elevation banner ══════════ -->
    <Border Grid.Row="1" Background="#1A2A3F52" BorderBrush="{StaticResource Brush.Stroke}"
            BorderThickness="0,1" Padding="16,8"
            Visibility="{Binding IsElevated, Converter={StaticResource BoolToVisInverted}}">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="&#xE7EF;" FontFamily="{StaticResource Font.Icons}" FontSize="13"
                     Foreground="{StaticResource Brush.Warning}" VerticalAlignment="Center"/>
          <TextBlock Margin="10,0,0,0" FontSize="12.5" Foreground="{StaticResource Brush.TextSecondary}"
                     VerticalAlignment="Center"
                     Text="Running without administrator rights — system categories (Windows Temp, Update cache, logs…) are locked."/>
        </StackPanel>
        <Button Content="Restart as administrator" HorizontalAlignment="Right" Padding="12,5"
                FontSize="12" Command="{Binding RestartAsAdminCommand}"/>
      </Grid>
    </Border>

    <!-- ══════════ Body ══════════ -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="216"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Nav rail -->
      <Border Grid.Column="0" Background="{StaticResource Brush.Bg}"
              BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="0,0,1,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,12">
            <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" Tag="&#xE713;" Content="Settings"
                         IsChecked="{Binding SelectedTab, Converter={x:Static views:TabIndexConverter.Instance}, ConverterParameter=5}"/>
            <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" Tag="&#xE946;" Content="About"
                         IsChecked="{Binding SelectedTab, Converter={x:Static views:TabIndexConverter.Instance}, ConverterParameter=6}"/>
          </StackPanel>
          <StackPanel Margin="0,10,0,0">
            <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" Tag="&#xE80F;" Content="Dashboard"
                         IsChecked="{Binding SelectedTab, Converter={x:Static views:TabIndexConverter.Instance}, ConverterParameter=0}"/>
            <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" Tag="&#xEA99;" Content="Clean"
                         IsChecked="{Binding SelectedTab, Converter={x:Static views:TabIndexConverter.Instance}, ConverterParameter=1}"/>
            <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" Tag="&#xE9D2;" Content="Analyzer"
                         IsChecked="{Binding SelectedTab, Converter={x:Static views:TabIndexConverter.Instance}, ConverterParameter=2}"/>
            <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" Tag="&#xE7BA;" Content="Space Hogs"
                         IsChecked="{Binding SelectedTab, Converter={x:Static views:TabIndexConverter.Instance}, ConverterParameter=3}"/>
            <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" Tag="&#xE90F;" Content="Tools"
                         IsChecked="{Binding SelectedTab, Converter={x:Static views:TabIndexConverter.Instance}, ConverterParameter=4}"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Pages -->
      <Grid Grid.Column="1">
        <views:DashboardView Visibility="{Binding SelectedTab, Converter={x:Static views:TabVisibilityConverter.Instance}, ConverterParameter=0}"/>
        <views:CleanView     Visibility="{Binding SelectedTab, Converter={x:Static views:TabVisibilityConverter.Instance}, ConverterParameter=1}"/>
        <views:AnalyzerView  Visibility="{Binding SelectedTab, Converter={x:Static views:TabVisibilityConverter.Instance}, ConverterParameter=2}"/>
        <views:HogsView      Visibility="{Binding SelectedTab, Converter={x:Static views:TabVisibilityConverter.Instance}, ConverterParameter=3}"/>
        <views:ToolsView     Visibility="{Binding SelectedTab, Converter={x:Static views:TabVisibilityConverter.Instance}, ConverterParameter=4}"/>
        <views:SettingsView  Visibility="{Binding SelectedTab, Converter={x:Static views:TabVisibilityConverter.Instance}, ConverterParameter=5}"/>
        <views:AboutView     Visibility="{Binding SelectedTab, Converter={x:Static views:TabVisibilityConverter.Instance}, ConverterParameter=6}"/>
      </Grid>
    </Grid>

    <!-- ══════════ Status bar ══════════ -->
    <Border Grid.Row="3" Background="{StaticResource Brush.BgElevated}"
            BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="0,1,0,0" Padding="16,6">
      <Grid>
        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{StaticResource Brush.TextSecondary}"
                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <TextBlock FontSize="12" Foreground="{StaticResource Brush.TextTertiary}" VerticalAlignment="Center">
            <Run Text="Lifetime freed:"/>
            <Run Text="{Binding LifetimeFreedText, Mode=OneWay}" Foreground="{StaticResource Brush.Success}"/>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>

  <!-- ══════════ Startup splash overlay ══════════ -->
  <Grid x:Name="Splash" Background="{StaticResource Brush.Bg}">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
      <Grid x:Name="SplashLogo" Width="220" Height="120" Opacity="0">
        <TextBlock Text="&#xEA99;" FontFamily="{StaticResource Font.Icons}" FontSize="64"
                   Foreground="{StaticResource Brush.Accent}"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0"
                   RenderTransformOrigin="0.25,0.85">
          <TextBlock.RenderTransform>
            <RotateTransform x:Name="SplashRotate" Angle="-26"/>
          </TextBlock.RenderTransform>
        </TextBlock>
        <Rectangle x:Name="Bit1" Width="9" Height="9" RadiusX="2" RadiusY="2"
                   Fill="{StaticResource Brush.Accent}" Opacity="0"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="96,-14,0,0">
          <Rectangle.RenderTransform>
            <TranslateTransform x:Name="Bit1Move"/>
          </Rectangle.RenderTransform>
        </Rectangle>
        <Rectangle x:Name="Bit2" Width="7" Height="7" RadiusX="2" RadiusY="2"
                   Fill="{StaticResource Brush.Success}" Opacity="0"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="92,10,0,0">
          <Rectangle.RenderTransform>
            <TranslateTransform x:Name="Bit2Move"/>
          </Rectangle.RenderTransform>
        </Rectangle>
        <Rectangle x:Name="Bit3" Width="6" Height="6" RadiusX="1.5" RadiusY="1.5"
                   Fill="#22D3EE" Opacity="0"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="100,-2,0,0">
          <Rectangle.RenderTransform>
            <TranslateTransform x:Name="Bit3Move"/>
          </Rectangle.RenderTransform>
        </Rectangle>
      </Grid>
      <TextBlock x:Name="SplashTitle" Text="BitBroom" FontSize="32" FontWeight="SemiBold"
                 Foreground="{StaticResource Brush.Text}" HorizontalAlignment="Center"
                 Opacity="0" Margin="0,6,0,0" RenderTransformOrigin="0.5,0.5">
        <TextBlock.RenderTransform>
          <ScaleTransform x:Name="TitleScale" ScaleX="0.92" ScaleY="0.92"/>
        </TextBlock.RenderTransform>
      </TextBlock>
      <TextBlock x:Name="SplashTag" Text="Reclaim your disk. Safely." FontSize="13"
                 Foreground="{StaticResource Brush.TextTertiary}" HorizontalAlignment="Center"
                 Opacity="0" Margin="0,6,0,0"/>
    </StackPanel>
  </Grid>

  </Grid>
</Window>
